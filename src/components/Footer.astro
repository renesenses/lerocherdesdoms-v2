---
import { url } from '../utils/paths'
const year = new Date().getFullYear()
---

<footer class="border-t border-white/10 mt-auto">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Contact -->
      <div>
        <h3 class="font-heading text-lg mb-3">Contact</h3>
        <p class="text-sm text-white/70 leading-relaxed">
          <a href="mailto:cielerocherdesdoms@orange.fr" class="text-white/70 hover:text-accent">cielerocherdesdoms@orange.fr</a><br />
          Sylvain Marmorat : 06 84 12 12 64<br />
          Laurence Boyenval : 06 87 35 45 93
        </p>
      </div>

      <!-- Navigation rapide -->
      <div>
        <h3 class="font-heading text-lg mb-3">Navigation</h3>
        <ul class="text-sm space-y-1">
          <li><a href={url('/spectacles')} class="text-white/70 hover:text-accent">Spectacles</a></li>
          <li><a href={url('/ecole')} class="text-white/70 hover:text-accent">École de Théâtre</a></li>
          <li><a href={url('/calendrier')} class="text-white/70 hover:text-accent">Calendrier</a></li>
          <li><a href={url('/contact')} class="text-white/70 hover:text-accent">Contact</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="font-heading text-lg mb-3">Newsletter</h3>
        <form id="newsletter-form" class="flex flex-col gap-2" action="https://formsubmit.co/ajax/cielerocherdesdoms@orange.fr" method="POST">
          <input type="hidden" name="_subject" value="Nouvelle inscription newsletter — Le Rocher des Doms" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />
          <input type="text" name="_honey" style="display:none" />
          <input
            type="email"
            name="email"
            placeholder="Votre email"
            aria-label="Email pour la newsletter"
            required
            class="w-full px-3 py-2 bg-transparent border border-white/30 text-white text-sm placeholder:text-white/40 focus:border-accent focus:outline-none transition-colors"
          />
          <button type="submit" id="newsletter-btn" class="bg-accent hover:bg-accent-dark text-white text-sm uppercase tracking-wider py-2 px-4 transition-colors">
            S'inscrire
          </button>
          <p id="newsletter-msg" class="text-sm hidden"></p>
        </form>
        <script>
          const nf = document.getElementById('newsletter-form') as HTMLFormElement
          const nm = document.getElementById('newsletter-msg')!
          const nb = document.getElementById('newsletter-btn') as HTMLButtonElement
          nf?.addEventListener('submit', async (e) => {
            e.preventDefault()
            nb.disabled = true
            nb.textContent = 'Envoi…'
            try {
              const res = await fetch(nf.action, {
                method: 'POST',
                body: new FormData(nf),
                headers: { 'Accept': 'application/json' }
              })
              if (res.ok) {
                nm.textContent = 'Merci pour votre inscription !'
                nm.className = 'text-sm text-green-400'
                nf.reset()
              } else {
                nm.textContent = 'Une erreur est survenue. Réessayez.'
                nm.className = 'text-sm text-red-400'
              }
            } catch {
              nm.textContent = 'Une erreur est survenue. Réessayez.'
              nm.className = 'text-sm text-red-400'
            }
            nb.disabled = false
            nb.textContent = "S'inscrire"
          })
        </script>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/50">
      <p>&copy; {year} Compagnie Le Rocher des Doms</p>
      <ul class="flex gap-4">
        <li><a href={url('/mentions-legales')} class="hover:text-white transition-colors">Mentions légales</a></li>
        <li><a href={url('/confidentialite')} class="hover:text-white transition-colors">Confidentialité</a></li>
      </ul>
    </div>
  </div>
</footer>
