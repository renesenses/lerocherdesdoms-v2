---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { url, asset } from '../../utils/paths'
---

<BaseLayout title="Le Médecin Volant — Critique — Le Rocher des Doms" description="Critique du Médecin Volant suite aux représentations au collège Henri Dunant de Dijon." currentPage="/spectacles">

  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-accent text-sm uppercase tracking-wider mb-4">Le Médecin Volant — Molière</p>
      <h1 class="font-heading text-3xl md:text-4xl mb-2">Le Médecin Volant — Critique</h1>
      <p class="text-white/50 text-sm mb-8">Mars 2016</p>

      <div class="space-y-6 text-white/80 leading-relaxed">
        <p>Suite aux représentations du lundi 21 mars à Dijon devant les élèves du collège Henri Dunant, le spectacle a reçu des réponses très positives du public scolaire, les élèves louant son humour, son originalité et son énergie dynamique.</p>
      </div>

      <div class="mt-12 flex gap-4">
        <a href={url('/spectacles/le-medecin-volant')} class="text-white/60 hover:text-accent uppercase text-sm tracking-wider font-bold transition-colors">&larr; Le Médecin Volant</a>
      </div>
    </div>
  </section>

</BaseLayout>
