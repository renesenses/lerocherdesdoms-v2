---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { url, asset } from '../../utils/paths'
---

<BaseLayout title="Le Petit Bonnet Rouge — Le Teaser — Le Rocher des Doms" description="Le teaser du spectacle Le Petit Bonnet Rouge." currentPage="/spectacles">

  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-accent text-sm uppercase tracking-wider mb-4">Le Petit Bonnet Rouge</p>
      <h1 class="font-heading text-3xl md:text-4xl mb-2">Le Petit Bonnet Rouge — Le Teaser</h1>
      <p class="text-white/50 text-sm mb-8">Juin 2023</p>

      <div class="space-y-6 text-white/80 leading-relaxed">
        <p class="text-lg italic text-wheat/90">Le Petit Bonnet Rouge, le conte, la danse, le théâtre, la musique&nbsp;: quatre domaines artistiques réunis pour raconter une histoire, partager des émotions, imager des scènes et se laisser entraîner par le rythme.</p>

        <p class="text-white/50 text-sm">Avec le soutien de l'ADAMI.</p>
      </div>

      <div class="mt-12 flex gap-4">
        <a href={url('/spectacles/le-petit-bonnet-rouge')} class="text-white/60 hover:text-accent uppercase text-sm tracking-wider font-bold transition-colors">&larr; Le Petit Bonnet Rouge</a>
      </div>
    </div>
  </section>

</BaseLayout>
