---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { url, asset } from '../../utils/paths'
---

<BaseLayout title="Louise Michel Louise Maboul — Dossier — Le Rocher des Doms" description="Dossier de présentation du spectacle Louise Michel Louise Maboul." currentPage="/spectacles">

  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-accent text-sm uppercase tracking-wider mb-4">Louise Michel — Louise Maboul</p>
      <h1 class="font-heading text-3xl md:text-4xl mb-2">Dossier de présentation</h1>
      <p class="text-white/50 text-sm mb-8">Juin 2022</p>

      <div class="space-y-6 text-white/80 leading-relaxed">
        <p>Le dossier de présentation du spectacle « Louise Michel — Louise Maboul ».</p>
        <p>N'hésitez pas à nous contacter pour plus d'informations.</p>
      </div>

      <div class="mt-8">
        <div class="border border-white/20 p-6 inline-block">
          <h3 class="font-heading text-lg mb-4">Distribution</h3>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-white/50 uppercase tracking-wider text-xs">Interprètes</dt>
              <dd>Sylvain Marmorat &amp; Laurence Boyenval</dd>
            </div>
          </dl>
        </div>
      </div>

      <div class="mt-12 flex gap-4">
        <a href={url('/archives')} class="text-white/60 hover:text-accent uppercase text-sm tracking-wider font-bold transition-colors">&larr; Archives</a>
      </div>
    </div>
  </section>

</BaseLayout>
