---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { url, asset } from '../../utils/paths'
---

<BaseLayout title="Les Derniers Devoirs au Théâtre — Le Rocher des Doms" description="Article du Bien Public sur Les Derniers Devoirs de Louis Calaferte." currentPage="/spectacles">

  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-accent text-sm uppercase tracking-wider mb-4">Les Derniers Devoirs — Louis Calaferte</p>
      <h1 class="font-heading text-3xl md:text-4xl mb-2">Les Derniers Devoirs au Théâtre</h1>
      <p class="text-white/50 text-sm mb-8">Le Bien Public — 8 janvier 2012</p>

      <div class="space-y-6 text-white/80 leading-relaxed">
        <p>La compagnie Le Rocher des Doms sur scène avec <em>Les Derniers Devoirs</em> de Louis Calaferte.</p>
      </div>

      <div class="mt-8">
        <div class="border border-white/20 p-6 inline-block">
          <h3 class="font-heading text-lg mb-4">Équipe</h3>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-white/50 uppercase tracking-wider text-xs">Texte</dt>
              <dd>Louis Calaferte</dd>
            </div>
            <div>
              <dt class="text-white/50 uppercase tracking-wider text-xs">Mise en scène</dt>
              <dd>Sylvain Marmorat</dd>
            </div>
            <div>
              <dt class="text-white/50 uppercase tracking-wider text-xs">Jeu</dt>
              <dd>Laurence Boyenval, Sylvain Marmorat, Bénédicte Ressot</dd>
            </div>
          </dl>
        </div>
      </div>

      <div class="mt-12 flex gap-4">
        <a href={url('/archives')} class="text-white/60 hover:text-accent uppercase text-sm tracking-wider font-bold transition-colors">&larr; Archives</a>
      </div>
    </div>
  </section>

</BaseLayout>
