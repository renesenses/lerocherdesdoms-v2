---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { url, asset } from '../../utils/paths'
---

<BaseLayout title="Le Petit Bonnet Rouge à Dijon — Le Rocher des Doms" description="Représentations du Petit Bonnet Rouge au Théâtre des Feuillants à Dijon." currentPage="/spectacles">

  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-accent text-sm uppercase tracking-wider mb-4">Le Petit Bonnet Rouge</p>
      <h1 class="font-heading text-3xl md:text-4xl mb-2">Le Petit Bonnet Rouge à Dijon</h1>
      <p class="text-white/50 text-sm mb-8">Septembre 2023</p>

      <div class="space-y-6 text-white/80 leading-relaxed">
        <p>Les 26 et 27 septembre au théâtre des Feuillants, la compagnie donne 4 représentations de sa dernière création <em>Le Petit Bonnet Rouge</em>.</p>

        <p>Les représentations scolaires du 26 septembre sont accessibles au public sur réservation.</p>

        <p>Les séances du mercredi 27 à 10h00 et 20h00 sont réservables auprès de la Compagnie avec billetterie en ligne.</p>
      </div>

      <div class="mt-12 flex gap-4">
        <a href={url('/spectacles/le-petit-bonnet-rouge')} class="text-white/60 hover:text-accent uppercase text-sm tracking-wider font-bold transition-colors">&larr; Le Petit Bonnet Rouge</a>
      </div>
    </div>
  </section>

</BaseLayout>
